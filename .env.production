# ---- Production Environment Configuration ----
# This file should be copied to .env and updated with actual production values

# Security (REQUIRED - Generate a strong random secret)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your_production_secret_key_here_minimum_32_characters

# Database Configuration
MONGODB_URL=mongodb+srv://your_production_db_user:your_password@cluster.mongodb.net/your_db
DATABASE_NAME=mindbridge_prod

# OpenAI API Configuration
OPENAI_API_KEY=your_production_openai_api_key
MAIN_MODEL=gpt-4o
SYNTHESIZER_MODEL=gpt-4o-mini

# Groq API Configuration
GROQ_API_KEY=your_production_groq_api_key
GROQ_WHISPER_MODEL=whisper-large-v3

# HuggingFace Emotion Model
HF_EMOTION_MODEL=SamLowe/roberta-base-go_emotions
# TODO: UPDATE FOR PROD - HF_API_TOKEN=your_hf_token

# Application Configuration
APP_NAME=MindBridge
APP_VERSION=1.0.0
DEBUG=false
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# Server Configuration
# TODO: UPDATE FOR PROD - SERVER_HOST=your_production_host
SERVER_PORT=8000

# LLM Parameters
LLM_TEMPERATURE=0.7
MAX_TOKENS=300

# Session & Memory Configuration
MAX_HISTORY_TURNS=50
# TODO: UPDATE FOR PROD - MEMORY_WINDOW_SIZE=20

# JWT Authentication
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Configuration (Optional)
# TODO: UPDATE FOR PROD - SENDER_EMAIL=your_production_email@gmail.com
# TODO: UPDATE FOR PROD - SENDER_PASSWORD=your_production_gmail_app_password

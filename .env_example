# ---- MindBridge Security ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Main LLM (OpenAI) ----
OPENAI_API_KEY=your_openai_api_key_here
MAIN_MODEL=gpt-4o
SYNTHESIZER_MODEL=gpt-4o-mini

# ---- STT (Groqwhisper) ----
GROQ_API_KEY=your_groq_api_key_here

# ---- Emotion Engine (HuggingFace) ----
HF_EMOTION_MODEL=SamLowe/roberta-base-go_emotions
HF_API_TOKEN=your_huggingface_token_here

# ---- Storage (MongoDB) ----
# Example: mongodb://localhost:27017 or your Atlas connection string
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=mindbridge_db

# ---- Communication (Gmail SMTP) ----
# Note: SENDER_PASSWORD should be a Gmail App Password
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password_here

# ---- General App Config ----
APP_ENV=development
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

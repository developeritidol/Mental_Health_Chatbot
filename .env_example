# ---- Mental Health Chatbot Configuration (Example File) ----
# IMPORTANT: Do NOT put real secrets here. Copy this file to .env and fill in real values.
# .env is git-ignored. This file is safe to commit.

# ── Application ───────────────────────────────────────────────
APP_NAME=MindBridge
DEBUG=False
SERVER_HOST=localhost
SERVER_PORT=8000

# ── Database ──────────────────────────────────────────────────
# Replace <user>, <password>, and <cluster> with your Atlas credentials.
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.<cluster>.mongodb.net/
DATABASE_NAME=mindbridge_db

# ── OpenAI (GPT-4o — generation + embeddings) ─────────────────
OPENAI_API_KEY=sk-your_openai_api_key_here
MAIN_MODEL=gpt-4o
SYNTHESIZER_MODEL=gpt-4o-mini

# ── Groq (Whisper STT + Llama-3 safety consensus) ────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_WHISPER_MODEL=whisper-large-v3

# ── HuggingFace Emotion Model ─────────────────────────────────
HF_EMOTION_MODEL=SamLowe/roberta-base-go_emotions
HF_API_TOKEN=

# ── Email Service (Gmail SMTP) ────────────────────────────────
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_gmail_app_password_here

# ── JWT Authentication ────────────────────────────────────────
# Must be at least 32 characters of random entropy.
JWT_SECRET_KEY=your_long_random_jwt_secret_key_here_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM Tuning ────────────────────────────────────────────────
MAX_HISTORY_TURNS=50
MAX_TOKENS=300
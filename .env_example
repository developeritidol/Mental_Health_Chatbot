# ---- Mental Health Chatbot Configuration ----

# Security (REQUIRED - Generate a strong random secret)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=your_jwt_secret_key_here_minimum_32_characters

# OpenAI API
OPENAI_API_KEY=your_api_key
MAIN_MODEL=gpt-4o

# Groq API
GROQ_API_KEY=your_groq_api_key

# HuggingFace Emotion Model
HF_EMOTION_MODEL=SamLowe/roberta-base-go_emotions
HF_API_TOKEN=your_hf_token

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# LLM Parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# Memory
MEMORY_WINDOW_SIZE=20

# MongoDB
MONGODB_URL=mongodb_connection


 
# JWT Authentication
JWT_SECRET_KEY=your_JWT_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7